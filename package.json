{
  "name": "vpn",
  "version": "1.0.4",
  "description": "vpncli — manage every VPN from your terminal",
  "type": "module",
  "bin": {
    "vpn": "./src/cli.tsx"
  },
  "scripts": {
    "dev": "bun run src/cli.tsx",
    "typecheck": "tsc --noEmit",
    "build": "bun run scripts/build.ts",
    "compile": "bun build --compile src/cli.tsx --outfile dist/vpn"
  },
  "dependencies": {
    "ink": "^7.0.5",
    "ink-gradient": "^4.0.1",
    "ink-spinner": "^5.0.0",
    "meow": "^13.2.0",
    "react": "^19.2.0",
    "react-devtools-core": "^6.1.5"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "bun-types": "^1.3.14",
    "typescript": "^5.6.0"
  },
  "engines": {
    "bun": ">=1.2.0"
  },
  "license": "MIT"
}
